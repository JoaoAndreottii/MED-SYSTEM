FROM node:20-alpine

WORKDIR /app

# Copy root package files
COPY package.json package-lock.json ./

# Copy apps
COPY apps/web ./apps/web

# Install dependencies
RUN npm install --legacy-peer-deps --workspace=@med-system/web --production

# Build Next.js
RUN npm -w @med-system/web run build

# Set environment
ENV NODE_ENV=production
ENV PORT=3001

# Expose port
EXPOSE 3001

# Start Next.js
CMD ["npm", "-w", "@med-system/web", "run", "start"]
