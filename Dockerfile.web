FROM node:20-alpine

WORKDIR /app

# Copy ONLY web files and root package
COPY package.json package-lock.json ./
COPY apps/web ./apps/web

# Install root deps
RUN npm install --legacy-peer-deps

# Go to web directory and install its specific deps
WORKDIR /app/apps/web
RUN npm install --legacy-peer-deps

# Build Next.js
RUN npm run build

# Remove node_modules and reinstall production-only
WORKDIR /app
RUN rm -rf node_modules apps/web/node_modules
RUN npm install --legacy-peer-deps --omit=dev
WORKDIR /app/apps/web
RUN npm install --legacy-peer-deps --omit=dev

EXPOSE 3001
ENV NODE_ENV=production
ENV NEXT_PUBLIC_API_URL=https://med-systemapi-production.up.railway.app
CMD ["npm", "start"]
