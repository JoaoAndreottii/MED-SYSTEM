{
  "name": "med-system",
  "version": "1.0.0",
  "description": "Medical clinic automation system - MVP with 9 core modules",
  "private": true,
  "scripts": {
    "dev": "cd apps/api && npm run dev",
    "build": "cd apps/api && npm run build",
    "test": "cd apps/api && npm run test",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:reset": "docker-compose down -v && docker-compose up -d"
  },
  "devDependencies": {
    "@types/node": "^20.14.5",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
