{
  "name": "med-system",
  "version": "1.0.0",
  "description": "Medical clinic automation system - MVP with 9 core modules",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm -w @med-system/api run dev",
    "build": "npm -r --exclude=@med-system/web run build && npm -w @med-system/web run build",
    "test": "npm -r run test",
    "test:watch": "npm -r run test:watch",
    "lint": "npm -r run lint",
    "format": "npm -r run format",
    "setup": "npm install && npm run prisma:generate",
    "prisma:generate": "npm -w @med-system/api run prisma:generate",
    "prisma:migrate": "npm -w @med-system/api run prisma:migrate",
    "prisma:push": "npm -w @med-system/api run prisma:push",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:reset": "docker-compose down -v && docker-compose up -d"
  },
  "devDependencies": {
    "@types/node": "^20.14.5",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
